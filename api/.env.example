# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/phantomcopy

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d

# ─── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PROPLUS=price_...

# ─── Proxy Providers ──────────────────────────────────────────────────────
BRIGHTDATA_ZONE=residential
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# ─── App ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://app.phantomcopy.com
API_URL=https://api.phantomcopy.com
